{
	"name": "electrobun-svelte",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with Svelte and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "vite build && electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.64.0",
		"@mariozechner/pi-agent-core": "^0.64.0",
		"@mariozechner/pi-web-ui": "^0.64.0",
		"@mariozechner/mini-lit": "^0.2.0",
		"lit": "^3.3.1",
		"electrobun": "1.16.0"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/bun": "^1.3.11",
		"concurrently": "^9.2.1",
		"svelte": "^5.55.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	}
}
